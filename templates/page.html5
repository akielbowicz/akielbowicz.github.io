<!DOCTYPE html>
<html lang="$lang$">
<head>
  <meta charset="$if(charset)$$charset$$else$utf-8$endif$" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>$pagetitle$ | ak.saxa.xyz</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="$css_path$" />
  <link rel="shortcut icon" href="$favicon_path$" />
  <link rel="apple-touch-icon" sizes="180x180" href="$apple_touch_icon_path$" />
  <link rel="icon" type="image/png" sizes="32x32" href="$favicon_32_path$" />
  <link rel="icon" type="image/png" sizes="64x64" href="$favicon_64_path$" />
$for(header-includes)$
  $header-includes$
$endfor$
</head>
<body>
  <div class="wrapper">
    <main>
      <nav>$nav_html$</nav>
$body$
    </main>
  </div>
  <footer>
    <p><small>$footer_text$ <a href="https://www.linkedin.com/in/augusto-kiel/" target="_blank" rel="noopener noreferrer">$footer_link_text$</a>.</small></p>
  </footer>
</body>
</html>
